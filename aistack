}


# Main function
main() {
    if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        usage
        exit 0
    fi

    if [ "$#" -eq 0 ]; then
        usage
        exit 1
    fi

    local command="$1"
    shift
    case "$command" in
        help)
            usage
            exit 0
            ;;
        shell)
            $STELLA_API boot_app_shell "local"
			exit 0
            ;;
        info)
            aistack_info
			exit 0
            ;;
        init)
			# NOTE : aistack_install uninstall everything
            aistack_install

            aistack_initialize
            aistack_runtime_detect
            aistack_module_detect
		    aistack_run_context_file_generate
            aistack_tool_detect
            aistack_mcp_detect
            aistack_launcher_regenerate
			exit 0
            ;;
        uninstall)
            aistack_uninstall

            aistack_initialize
            aistack_runtime_detect
			aistack_module_detect
            aistack_run_context_file_generate
            aistack_tool_detect
            aistack_mcp_detect
            aistack_launcher_regenerate
			exit 0
            ;;
	esac


	# next commands requires core components installed
	aistack_component_core_is_detected



	case "$command" in
        bun)
            if ! aistack_runtime_is_detected "bun"; then echo " -- ERROR : bun managed runtime missing, use aistack runtime command"; exit 1; fi;     
			PATH="${AISTACK_RUNTIME_BUN_SEARCH_PATH}:${STELLA_ORIGINAL_SYSTEM_PATH}" "$command" "$@"
            ;;
        npm|npx)
            if ! aistack_runtime_is_detected "nodejs"; then echo " -- ERROR : nodejs managed runtime missing, use aistack runtime command"; exit 1; fi;     
			PATH="${AISTACK_RUNTIME_NODEJS_SEARCH_PATH}:${STELLA_ORIGINAL_SYSTEM_PATH}" "$command" "$@"
            ;;
        nvm)
            if ! aistack_runtime_is_detected "nodejs"; then echo " -- ERROR : nodejs managed runtime missing, use aistack runtime command"; exit 1; fi;     
            if [ "${AISTACK_MODULE_NVM_AVAILABLE}" = "true" ]; then
                "${command}" "$@"
            else
                echo " -- WARN : $command not found - reinstall nodejs managed runtime."
                exit 1
            fi
            ;;
        pip|pipx|uv)
            if ! aistack_runtime_is_detected "python"; then echo " -- ERROR : python managed runtime missing, use aistack runtime command"; exit 1; fi;     
            PATH="${AISTACK_RUNTIME_PYTHON_SEARCH_PATH}:${STELLA_ORIGINAL_SYSTEM_PATH}" "$command" "$@"
            ;;
		runtime)
			local sub_command="$1"
			shift
            case "${sub_command}" in
                add)
					aistack_runtime_install "$1"
					aistack_runtime_detect
					aistack_run_context_file_generate
				;;
				remove)
					aistack_runtime_uninstall "$1"
					aistack_runtime_detect
					aistack_run_context_file_generate
				;;
				*)
					echo "ERROR: Unknown command ${sub_command} for runtime"
					usage
					exit 1
				;;
			esac
			;;
        app)
            local sub_command="$1"
            shift
            case "${sub_command}" in
                killport)
                    local port="$1"
                    shift
                    if [ -z "$port" ]; then
                        echo " -- ERROR : Missing port for app killport"
                        usage
                        exit 1
                    fi
                    process_kill_by_port "$port"
                    ;;
                *)
                    echo "ERROR: Unknown command ${sub_command} for app"
                    usage
                    exit 1
                    ;;
            esac
            ;;
        oc)
            . "${_CURRENT_FILE_DIR}/lib/main_oc.sh"
            ;;
        gc)
            . "${_CURRENT_FILE_DIR}/lib/main_gc.sh"
            ;;
        cpa)
            . "${_CURRENT_FILE_DIR}/lib/main_cpa.sh"
            ;;
        agy)
            . "${_CURRENT_FILE_DIR}/lib/main_agy.sh"
            ;;
        vs)
            . "${_CURRENT_FILE_DIR}/lib/main_vs.sh"
            ;;
        orla)
            . "${_CURRENT_FILE_DIR}/lib/main_orla.sh"
            ;;
        bmad)
            . "${_CURRENT_FILE_DIR}/lib/main_bmad.sh"
            ;;
		gsd)
            . "${_CURRENT_FILE_DIR}/lib/main_gsd.sh"
            ;;
        adk)
            . "${_CURRENT_FILE_DIR}/lib/main_adk.sh"
            ;;
        kc)
            . "${_CURRENT_FILE_DIR}/lib/main_kilo.sh"
            ;;
        asm)
            . "${_CURRENT_FILE_DIR}/lib/main_asm.sh"
            ;;
        *)
            echo "ERROR: Unknown command $command"
            usage
            exit 1
            ;;
    esac

    
}

aistack_initialize

aistack_runtime_detect
aistack_module_detect

aistack_run_context_file_generate

aistack_tool_detect
aistack_mcp_detect
aistack_launcher_regenerate

main "$@"
